---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const intro = await getEntry('sections', 'approach');
const detail = await getEntry('sections', 'approach-detail');
const { Content: Intro } = await render(intro!);
const { Content: Detail } = await render(detail!);

const pillars = (await getCollection('pillars')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="The Approach — Mind Coding Institute" docs>
  <article class="prose">
    <h1>{intro!.data.title}</h1>
    <Intro />
  </article>

  <ul class="pillar-list creed" id="creed">
    {
      pillars.map((p) => (
        <li>
          <a href={`/pillars/${p.id}`}>
            <span class="arrow">&gt;</span>
            {p.data.name}
          </a>
          <span class="summary">{p.data.summary}</span>
        </li>
      ))
    }
  </ul>

  <article class="prose">
    <Detail />
  </article>
</BaseLayout>
